{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "config/**",
          "public/**",
          "package.json"
        ]
      }
    },
    { "src": "api/test.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/test", "destination": "/api/test.js" },
    { "source": "/(.*)", "destination": "/api/server.js" }
  ]
}