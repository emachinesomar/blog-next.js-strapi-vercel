{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog articles"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "customField",
      "customField": "plugin::tinymce.tinymce",
      "options": {
        "disableMediaLibrary": false
      }
    },
    "contents": {
      "type": "text",
      "maxLength": 500000
    },
    "publishDate": {
      "type": "datetime"
    },
    "tags": {
      "type": "json"
    },
    "featuredImage": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "author": {
      "type": "json"
    }
  }
}
